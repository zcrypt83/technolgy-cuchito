@startuml Diagrama de Casos de Uso - Sistema SaaS Control de Inventario

title Diagrama de Casos de Uso\nSistema SaaS de Control de Inventario - Technology Cuchito

left to right direction
skinparam packageStyle rectangle

actor "Administrador" as Admin
actor "Encargado de Almacén" as Encargado
actor "Usuario Operativo" as Usuario

rectangle "Sistema SaaS de Control de Inventario" {
  
  package "Módulo de Autenticación y Seguridad" {
    usecase "Iniciar Sesión" as UC01
    usecase "Cerrar Sesión" as UC02
    usecase "Gestionar Usuarios" as UC03
    usecase "Asignar Roles y Permisos" as UC04
    usecase "Cambiar Contraseña" as UC05
  }
  
  package "Módulo de Gestión de Productos" {
    usecase "Registrar Producto" as UC06
    usecase "Actualizar Producto" as UC07
    usecase "Consultar Productos" as UC08
    usecase "Buscar y Filtrar Productos" as UC09
    usecase "Desactivar Producto" as UC10
    usecase "Gestionar Categorías" as UC11
  }
  
  package "Módulo de Gestión de Almacenes" {
    usecase "Registrar Almacén" as UC12
    usecase "Actualizar Almacén" as UC13
    usecase "Consultar Almacenes" as UC14
    usecase "Asignar Encargado" as UC15
    usecase "Desactivar Almacén" as UC16
  }
  
  package "Módulo de Gestión de Inventario" {
    usecase "Registrar Entrada de Inventario" as UC17
    usecase "Registrar Salida de Inventario" as UC18
    usecase "Consultar Stock en Tiempo Real" as UC19
    usecase "Transferir entre Almacenes" as UC20
    usecase "Confirmar Recepción de Transferencia" as UC21
    usecase "Realizar Ajuste de Inventario" as UC22
  }
  
  package "Módulo de Alertas y Notificaciones" {
    usecase "Configurar Alertas de Stock Mínimo" as UC23
    usecase "Recibir Notificaciones" as UC24
    usecase "Consultar Productos en Nivel Crítico" as UC25
  }
  
  package "Módulo de Reportes y Análisis" {
    usecase "Generar Reporte de Stock Actual" as UC26
    usecase "Generar Reporte de Movimientos" as UC27
    usecase "Generar Reporte de Rotación" as UC28
    usecase "Generar Reporte de Valorización" as UC29
    usecase "Visualizar Dashboard Ejecutivo" as UC30
    usecase "Exportar Reportes" as UC31
    usecase "Generar Análisis de Tendencias" as UC32
  }
  
  package "Módulo de Auditoría" {
    usecase "Consultar Historial de Movimientos" as UC33
    usecase "Consultar Log de Auditoría" as UC34
    usecase "Generar Reporte de Auditoría" as UC35
  }
}

