@startuml
title Diagrama de Casos de Uso\nSistema SaaS de Inventario - Technology Cuchito

left to right direction
skinparam packageStyle rectangle

actor "Administrador" as Admin
actor "Encargado de Almacén" as Encargado
actor "Usuario Operativo" as Operativo

rectangle "Sistema SaaS de Inventario" {
  package "Autenticación" {
    usecase "Iniciar sesión" as UC_Login
    usecase "Cerrar sesión" as UC_Logout
    usecase "Ver perfil" as UC_Profile
    usecase "Cambiar contraseña" as UC_Password
  }

  package "Catálogo y Maestros" {
    usecase "Consultar productos" as UC_ProductosRead
    usecase "Gestionar productos\n(Crear/Editar/Eliminar)" as UC_ProductosWrite
    usecase "Gestionar categorías" as UC_Categorias
    usecase "Gestionar proveedores" as UC_Proveedores
    usecase "Consultar almacenes" as UC_AlmacenesRead
    usecase "Gestionar almacenes\n(Crear/Editar/Eliminar)" as UC_AlmacenesWrite
  }

  package "Inventario y Operaciones" {
    usecase "Consultar inventario" as UC_InventarioRead
    usecase "Actualizar inventario" as UC_InventarioUpdate
    usecase "Registrar movimiento" as UC_MovBase
    usecase "Entrada" as UC_MovEntrada
    usecase "Salida" as UC_MovSalida
    usecase "Transferencia" as UC_MovTransfer
    usecase "Ajuste" as UC_MovAjuste
  }

  package "Usuarios, Configuración y Auditoría" {
    usecase "Gestionar usuarios" as UC_Usuarios
    usecase "Administrar panel de configuración" as UC_ConfigPanel
    usecase "Actualizar permisos por rol" as UC_ConfigPermisos
    usecase "Actualizar acciones auditables" as UC_ConfigAcciones
    usecase "Consultar auditoría" as UC_Auditoria
    usecase "Consultar auditoría por\nusuario/entidad" as UC_AuditoriaFiltro
  }

  package "Monitoreo" {
    usecase "Visualizar dashboard" as UC_Dashboard
  }
}

Admin --> UC_Login
Admin --> UC_Logout
Admin --> UC_Profile
Admin --> UC_Password
Admin --> UC_ProductosRead
Admin --> UC_ProductosWrite
Admin --> UC_Categorias
Admin --> UC_Proveedores
Admin --> UC_AlmacenesRead
Admin --> UC_AlmacenesWrite
Admin --> UC_InventarioRead
Admin --> UC_InventarioUpdate
Admin --> UC_MovBase
Admin --> UC_Usuarios
Admin --> UC_ConfigPanel
Admin --> UC_ConfigPermisos
Admin --> UC_ConfigAcciones
Admin --> UC_Auditoria
Admin --> UC_AuditoriaFiltro
Admin --> UC_Dashboard

Encargado --> UC_Login
Encargado --> UC_Logout
Encargado --> UC_Profile
Encargado --> UC_Password
Encargado --> UC_ProductosRead
Encargado --> UC_ProductosWrite
Encargado --> UC_Categorias
Encargado --> UC_Proveedores
Encargado --> UC_AlmacenesRead
Encargado --> UC_InventarioRead
Encargado --> UC_InventarioUpdate
Encargado --> UC_MovBase
Encargado --> UC_Dashboard

Operativo --> UC_Login
Operativo --> UC_Logout
Operativo --> UC_Profile
Operativo --> UC_Password
Operativo --> UC_ProductosRead
Operativo --> UC_AlmacenesRead
Operativo --> UC_InventarioRead
Operativo --> UC_MovBase
Operativo --> UC_Dashboard

UC_ConfigPermisos ..> UC_ConfigPanel : <<include>>
UC_ConfigAcciones ..> UC_ConfigPanel : <<include>>
UC_AuditoriaFiltro ..> UC_Auditoria : <<include>>
UC_MovEntrada ..> UC_MovBase : <<extend>>
UC_MovSalida ..> UC_MovBase : <<extend>>
UC_MovTransfer ..> UC_MovBase : <<extend>>
UC_MovAjuste ..> UC_MovBase : <<extend>>

note right of Admin
Acceso completo.
Incluye administración de permisos
y acciones auditables.
end note

note right of Encargado
Opera sobre su(s) almacén(es)
asignado(s), con permisos
operativos ampliados.
end note

note right of Operativo
En backend solo puede registrar
movimientos tipo "salida".
end note

@enduml
