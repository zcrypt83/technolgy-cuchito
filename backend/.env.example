# Backend Environment Configuration
# ===================================
# Copia este archivo como .env y rellena los valores para tu entorno

# ========== SERVIDOR ==========
PORT=5000
NODE_ENV=development

# ========== BASE DE DATOS ==========
# Opción recomendada en Render:
# DATABASE_URL=postgresql://usuario:password@host:5432/dbname
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=technology_cuchito_db
DB_USER=postgres
DB_PASSWORD=admin123
# true si tu proveedor exige SSL (en Render interno suele ser false)
DB_SSL=false
# ⚠️ Solo usar true si quieres recrear tablas desde cero (borra datos)
DB_SYNC_FORCE=false

# ========== JWT (SEGURIDAD) ==========
# ⚠️ IMPORTANTE: Generar un secret único para producción
# Ejecuta: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=default-secret-change-in-production
JWT_EXPIRE=7d

# ========== REDIS (CACHE DISTRIBUIDO) ==========
# Redis es CRÍTICO para producción (80% de mejora de performance)
# Opción recomendada en Render:
# REDIS_URL=redis://default:password@host:6379
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========== CORS (SEGURIDAD) ==========
# URL del frontend para permitir requests cross-origin
CORS_ORIGIN=http://localhost:5173

# ========== RATE LIMITING ==========
# Ventana en milisegundos y máximo de solicitudes por ventana
# API general ampliada para soportar alta concurrencia (ej: más almacenes)
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_API_WINDOW_MS=900000
RATE_LIMIT_API_MAX=50000

# ========== LOGGING ==========
# Niveles: error, warn, info, debug
LOG_LEVEL=info

# ========== CONFIGURACIÓN SEGÚN ENTORNO ==========
# Para DEVELOPMENT:
# - Todos los logs se muestran
# - JWT_SECRET puede ser default (pero es inseguro)
# - Base de datos local suficiente
# - Redis es opcional pero recomendado

# Para PRODUCTION:
# - NODE_ENV=production
# - JWT_SECRET debe ser único (64+ caracteres aleatorios)
# - Redis DEBE estar disponible
# - Base de datos debe tener replicas
# - DB_PASSWORD debe ser segura
# - LOG_LEVEL=warn o info (no debug)
