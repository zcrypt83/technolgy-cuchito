# Frontend Environment Configuration
# ====================================
# Copia este archivo como .env.local y personaliza según tu entorno

# Backend API URL
VITE_API_URL=http://localhost:5000/api

# Configuración de la aplicación
VITE_APP_NAME=Technology Cuchito
VITE_NODE_ENV=development

# Para desarrollo: http://localhost:5000/api
# Para staging: https://staging-api.yourdomain.com/api
# Para producción (Render): https://tu-backend.onrender.com/api
